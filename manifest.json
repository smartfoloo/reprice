{
  "manifest_version": 3,
  "name": "Reprice",
  "version": "1.0",
  "description": "Repriceは大手不動産ポータルサイトで中古物件の相場価格を表示することができるChrome拡張機能です。",
  "permissions": [],
  "host_permissions": [
    "https://raw.githubusercontent.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "*://suumo.jp/*",
        "*://*.suumo.jp/*"
      ],
      "js": [
        "csv-loader.js",
        "content/suumo.js"
      ],
      "css": [
        "style.css"
      ]
    },
    {
      "matches": [
        "*://realestate.yahoo.co.jp/*"
      ],
      "js": [
        "csv-loader.js",
        "content/yahoo.js"
      ],
      "css": [
        "style.css"
      ]
    },
    {
      "matches": [
        "*://athome.co.jp/*",
        "*://*.athome.co.jp/*"
      ],
      "js": [
        "csv-loader.js",
        "content/athome.js"
      ],
      "css": [
        "style.css"
      ]
    }
  ],
  "web_accessible_resources": [],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}